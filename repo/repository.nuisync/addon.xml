<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.nuisync"
       name="NuiSync Repository"
       version="1.0.0"
       provider-name="NuiSync">
  <extension point="xbmc.addon.repository"
             name="NuiSync Repository~">
    <dir>
      <info compressed="false">https://swiftakira.github.io/nuisync-kodi/repo/addons.xml</info>
      <checksum>https://swiftakira.github.io/nuisync-kodi/repo/addons.xml.md5</checksum>
      <datadir zip="true">https://swiftakira.github.io/nuisync-kodi/repo/</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary lang="en">NuiSync repo~ Install and update NuiSync from here!</summary>
    <description lang="en">The official NuiSync repository for Kodi. Provides automatic updates for the NuiSync watch-together addon~</description>
    <platform>all</platform>
  </extension>
</addon>
